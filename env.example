* { box-sizing: border-box; }

:root {
  --bg: #050505;
  --panel: rgba(15,15,17,.78);
  --panel2: rgba(255,255,255,.045);
  --border: rgba(255,255,255,.105);
  --text: #ffffff;
  --muted: #a1a1aa;
  --soft: #71717a;
  --danger: #ef4444;
}

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
}

button, input { font: inherit; }
button { cursor: pointer; }
audio { width: 100%; height: 38px; filter: invert(1); opacity: .92; }

.landing {
  min-height: 100vh;
  padding: 34px clamp(22px, 5vw, 72px);
  background:
    radial-gradient(circle at 50% 0%, rgba(255,255,255,.16), transparent 38%),
    radial-gradient(circle at 85% 70%, rgba(255,255,255,.07), transparent 25%),
    #000;
  position: relative;
  overflow: hidden;
}

.nav, .appHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 18px;
  font-weight: 850;
  letter-spacing: -0.04em;
}

.logo {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  background: #fff;
  color: #000;
  display: grid;
  place-items: center;
  font-weight: 950;
  box-shadow: 0 0 34px rgba(255,255,255,.16);
}

.navLinks {
  display: flex;
  gap: 28px;
  color: var(--muted);
  font-size: 14px;
}

.hero {
  min-height: calc(100vh - 90px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-width: 960px;
  position: relative;
  z-index: 2;
}

.livePill {
  width: fit-content;
  display: flex;
  align-items: center;
  gap: 9px;
  color: #d4d4d8;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.045);
  padding: 10px 14px;
  border-radius: 999px;
  margin-bottom: 24px;
  font-size: 14px;
  backdrop-filter: blur(16px);
}

.livePill i, .eyebrow i {
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #fff;
  display: block;
  box-shadow: 0 0 18px rgba(255,255,255,.9);
}

.hero h1 {
  margin: 0;
  max-width: 900px;
  font-size: clamp(54px, 9vw, 112px);
  line-height: .88;
  letter-spacing: -.078em;
}

.hero p {
  max-width: 720px;
  color: var(--muted);
  font-size: clamp(18px, 2vw, 22px);
  line-height: 1.55;
  margin: 26px 0 0;
}

.buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  margin-top: 40px;
}

.primary, .secondary, .ghost {
  border: 0;
  border-radius: 18px;
  min-height: 54px;
  padding: 0 26px;
  font-weight: 850;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  transition: transform .18s ease, background .18s ease, opacity .18s ease;
}

.primary:hover, .secondary:hover, .ghost:hover { transform: translateY(-1px); }
.primary { background: white; color: black; }
.secondary { background: transparent; color: white; border: 1px solid rgba(255,255,255,.15); }
.ghost { background: rgba(255,255,255,.045); color: white; border: 1px solid var(--border); }
.primary.compact { min-height: 46px; padding: 0 18px; }
.primary:disabled { opacity: .62; cursor: wait; }

.app {
  min-height: 100vh;
  background: radial-gradient(circle at 50% -20%, rgba(255,255,255,.08), transparent 28%), #000;
}

.appHeader {
  position: sticky;
  top: 0;
  z-index: 10;
  padding: 16px clamp(18px, 4vw, 48px);
  border-bottom: 1px solid rgba(255,255,255,.09);
  background: rgba(0,0,0,.78);
  backdrop-filter: blur(16px);
}

.brand small {
  display: block;
  margin-top: 2px;
  font-size: 11px;
  font-weight: 500;
  color: var(--soft);
  letter-spacing: 0;
}

.headerActions, .modalRight { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

.errorBox {
  width: min(1460px, calc(100% - 32px));
  margin: 14px auto 0;
  padding: 12px 14px;
  border-radius: 16px;
  background: rgba(127,29,29,.62);
  border: 1px solid rgba(248,113,113,.35);
}

.grid {
  width: min(1460px, calc(100% - 32px));
  margin: 0 auto;
  padding: 20px 0 30px;
  display: grid;
  grid-template-columns: 310px minmax(0, 1fr) 350px;
  gap: 20px;
}

.panel, .post, .chat, .roomIntro, .modalCard {
  border: 1px solid var(--border);
  background: var(--panel);
  backdrop-filter: blur(20px);
  border-radius: 28px;
  box-shadow: 0 26px 80px rgba(0,0,0,.22);
}

.left { display: flex; flex-direction: column; gap: 20px; }
.panel { padding: 20px; }

.panelTitle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
  gap: 12px;
}

.panelTitle h2 {
  margin: 0;
  font-size: 16px;
}

.tabRow { display: flex; gap: 6px; margin-bottom: 14px; }

.tab {
  flex: 1;
  min-height: 34px;
  border-radius: 999px;
  color: var(--muted);
  border: 1px solid var(--border);
  background: transparent;
  font-size: 12px;
  font-weight: 760;
}

.tab.active { background: white; color: black; }

.rankRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  border-radius: 18px;
  background: var(--panel2);
  padding: 12px;
  margin-bottom: 10px;
}

.rankLeft {
  display: flex;
  align-items: center;
  gap: 11px;
  min-width: 0;
}

.rankNo {
  width: 32px;
  height: 32px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: white;
  color: black;
  font-weight: 900;
  flex: none;
}

.rankLeft strong { display: block; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rankLeft p { margin: 2px 0 0; color: var(--soft); font-size: 12px; white-space: nowrap; }

.duelGrid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

.duelBox {
  text-align: left;
  color: white;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.035);
  border-radius: 20px;
  padding: 14px;
}

.duelBox span, .duelBox small { color: var(--muted); font-size: 12px; }
.duelBox strong { display: block; margin: 6px 0 10px; font-size: 28px; }

.meter {
  height: 6px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(255,255,255,.1);
  margin-bottom: 8px;
}

.meter i {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: #fff;
  transition: width .22s ease;
}

.pillLight {
  padding: 6px 10px;
  border-radius: 999px;
  background: white;
  color: black;
  font-size: 11px;
  font-weight: 850;
}

.microcopy {
  color: var(--soft);
  font-size: 13px;
  line-height: 1.55;
  margin: 14px 0 0;
}

.feed { display: flex; flex-direction: column; gap: 18px; }

.roomIntro {
  padding: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18px;
}

.roomIntro h1 { margin: 0; font-size: 28px; letter-spacing: -.04em; }
.roomIntro p { margin: 4px 0 0; color: var(--soft); }
.roomIntro span {
  color: var(--muted);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 9px 12px;
  font-size: 13px;
  white-space: nowrap;
}

.post { padding: 20px; animation: fadeUp .28s ease both; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

.postTop {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 16px;
}

.eyebrow {
  color: var(--muted);
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 7px;
}

.post h3 { margin: 5px 0 3px; font-size: 20px; }
.post p { margin: 0; color: var(--soft); font-size: 14px; }

.score {
  min-width: 116px;
  text-align: right;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.04);
  border-radius: 20px;
  padding: 12px 14px;
}

.score span {
  display: block;
  color: var(--soft);
  text-transform: uppercase;
  letter-spacing: .18em;
  font-size: 10px;
}

.score strong { display: block; line-height: 1; font-size: 36px; margin-top: 6px; }

.player {
  display: flex;
  align-items: center;
  gap: 16px;
  border: 1px solid var(--border);
  background: rgba(255,255,255,.035);
  border-radius: 22px;
  padding: 14px;
}

.play {
  width: 46px;
  height: 46px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  border: 0;
  background: white;
  color: black;
  flex: none;
}

.wave {
  height: 58px;
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 1;
  overflow: hidden;
}

.wave span {
  width: 5px;
  min-height: 6px;
  border-radius: 999px;
  background: rgba(255,255,255,.78);
}

.reactions { margin-top: 14px; display: flex; flex-wrap: wrap; gap: 9px; }

.reactions button {
  border: 1px solid var(--border);
  color: #d4d4d8;
  background: transparent;
  border-radius: 999px;
  min-height: 34px;
  padding: 0 13px;
}

.chat {
  min-height: 680px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chatHeader { padding: 20px; border-bottom: 1px solid var(--border); }
.chatHeader h2 { margin: 0; font-size: 16px; }
.chatHeader p { margin: 4px 0 0; color: var(--soft); font-size: 12px; }

.chatMessages {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 16px;
  overflow: auto;
}

.bubble {
  color: #d4d4d8;
  background: rgba(255,255,255,.04);
  border-radius: 18px;
  padding: 11px 12px;
  font-size: 14px;
  line-height: 1.4;
}

.bubble span { color: var(--soft); margin-right: 8px; }

.chatInput {
  display: flex;
  gap: 8px;
  padding: 14px;
  border-top: 1px solid var(--border);
}

.chatInput input {
  flex: 1;
  min-width: 0;
  border: 1px solid var(--border);
  background: #000;
  color: white;
  border-radius: 16px;
  padding: 0 14px;
  outline: 0;
}

.chatInput button {
  width: 46px;
  height: 46px;
  border: 0;
  border-radius: 16px;
  background: white;
  color: black;
  font-weight: 900;
}

.modalOverlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.72);
  backdrop-filter: blur(16px);
  z-index: 50;
  display: grid;
  place-items: center;
  padding: 20px;
}

.modalCard {
  width: min(620px, 100%);
  padding: 24px;
}

.modalCard h2 { margin: 0; font-size: 30px; letter-spacing: -.04em; }
.modalCard p { color: var(--muted); line-height: 1.55; }

.recordPanel {
  border: 1px solid var(--border);
  background: rgba(255,255,255,.035);
  border-radius: 24px;
  padding: 16px;
  margin: 18px 0;
}

.recordStatus {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 12px;
}

.timer {
  font-size: 34px;
  font-weight: 900;
  letter-spacing: -.05em;
}

.statusPill {
  color: var(--muted);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 8px 11px;
  font-size: 12px;
  font-weight: 750;
}

.statusPill.recording {
  color: white;
  border-color: rgba(239,68,68,.45);
  background: rgba(239,68,68,.16);
}

.scanSteps { display: grid; gap: 8px; margin-top: 12px; }

.scanSteps div {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 12px;
  border-radius: 14px;
  background: rgba(255,255,255,.04);
  color: var(--muted);
  font-size: 13px;
}

.scanSteps b { color: white; }

.modalActions {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 18px;
}

.danger {
  background: rgba(239,68,68,.14);
  color: white;
  border: 1px solid rgba(239,68,68,.35);
}

@media (max-width: 1100px) {
  .grid { grid-template-columns: 1fr; }
  .left { display: grid; grid-template-columns: repeat(2, 1fr); }
  .chat { min-height: 520px; }
}

@media (max-width: 720px) {
  .navLinks { display: none; }
  .hero h1 { font-size: 58px; }
  .left { grid-template-columns: 1fr; }
  .roomIntro, .postTop { align-items: flex-start; flex-direction: column; }
  .score { width: 100%; text-align: left; }
  .duelGrid { grid-template-columns: 1fr; }
  .headerActions { justify-content: flex-end; }
  .primary, .secondary, .ghost { min-height: 46px; padding: 0 16px; }
}
